# Base URL used by metadata/canonical tags in apps/web
NEXT_PUBLIC_APP_BASE_URL=http://localhost:3000

# Turso / Drizzle (database)
# Example: libsql://openbacklog-<team>.turso.io
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Optional: GitHub token used to increase rate limits for stars requests.
# Create one at: https://github.com/settings/tokens (public_repo is enough)
GITHUB_TOKEN=
