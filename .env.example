# Base URL used by metadata/canonical tags in apps/web
NEXT_PUBLIC_APP_BASE_URL=http://localhost:3000

# Turso / Drizzle (database)
# Example: libsql://openbacklog-<team>.turso.io
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Resend email delivery
# Example: re_123
RESEND_API_KEY=
# Example: OpenBacklog <hello@updates.openbacklog.app>
RESEND_FROM_EMAIL=
# Admin inbox that receives a notification on each new waitlist registration
WAITLIST_ADMIN_EMAIL=
# Optional dedicated inbox for roadmap suggestions.
# If empty, WAITLIST_ADMIN_EMAIL will be used.
ROADMAP_SUGGESTIONS_ADMIN_EMAIL=

# Optional: GitHub token used to increase rate limits for stars requests.
# Create one at: https://github.com/settings/tokens (public_repo is enough)
GITHUB_TOKEN=
