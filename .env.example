# Base URL used by metadata/canonical tags in apps/web
NEXT_PUBLIC_APP_BASE_URL=http://localhost:3000
# Better Auth canonical base URL (optional, defaults to NEXT_PUBLIC_APP_BASE_URL)
BETTER_AUTH_URL=http://localhost:3000
# Better Auth signing/encryption secret (required in production)
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Google Analytics 4 Measurement ID (example: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Google Search Console verification token (meta tag)
GOOGLE_SITE_VERIFICATION=

# Turso / Drizzle (database)
# Example: libsql://openbacklog-<team>.turso.io
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Resend email delivery
# Example: re_123
RESEND_API_KEY=
# Example: OpenBacklog <hello@updates.openbacklog.app>
RESEND_FROM_EMAIL=
# Admin inbox for product notifications (roadmap suggestions fallback)
PRODUCT_ADMIN_EMAIL=
# Optional dedicated inbox for roadmap suggestions.
# If empty, PRODUCT_ADMIN_EMAIL will be used.
ROADMAP_SUGGESTIONS_ADMIN_EMAIL=

# Optional: GitHub token used to increase rate limits for stars requests.
# Create one at: https://github.com/settings/tokens (public_repo is enough)
GITHUB_TOKEN=
# GitHub OAuth app credentials for Better Auth social login
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth credentials for Better Auth social login
# Callback URL: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# IGDB API (Twitch OAuth client credentials)
# Create app credentials at: https://dev.twitch.tv/console/apps
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=
# Optional tuning knobs for IGDB consumption and local cache behavior
IGDB_SYNC_TTL_HOURS=24
IGDB_SEARCH_CACHE_TTL_MS=60000
IGDB_REQUEST_TIMEOUT_MS=10000
IGDB_MAX_RETRIES=3
